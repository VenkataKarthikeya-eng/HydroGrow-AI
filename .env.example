# HydroGrow AI Production & Environment Configuration Template

# Database Connection (Default PostgreSQL or local fallback)
DATABASE_URL=postgresql://hydrogrow_user:secure_password_here@localhost:5432/hydrogrow_db

# Security & Authentication
JWT_SECRET_KEY=super_secret_jwt_key_replace_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application Environment
API_ENV=production
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# Machine Learning & Storage Settings
MODEL_PATH=backend/ml/models/saved/growth_model.joblib
STORAGE_PROVIDER=local

# Docker PostgreSQL Credentials (Used by Docker Compose)
POSTGRES_USER=hydrogrow_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=hydrogrow_db
